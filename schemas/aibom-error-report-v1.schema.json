{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://0disoft.example/schemas/aibom-error-report-v1.schema.json",
  "title": "AI-BOM Generator Error Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tool", "status", "error", "exit_code"],
  "properties": {
    "schema_version": { "const": "ai-bom-error-report/v1" },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "ai-bom-generator" },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "status": { "const": "failed" },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "stage", "message"],
      "properties": {
        "code": {
          "enum": ["INVALID_INPUT", "COLLECTOR_FAILURE", "EXPORTER_FAILURE", "INTERNAL_ERROR"]
        },
        "stage": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "exit_code": { "enum": [20, 30, 40, 70] }
  }
}
